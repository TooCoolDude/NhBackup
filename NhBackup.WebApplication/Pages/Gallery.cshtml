@page "{id}"
@model NhBackup.WebApplication.Pages.GalleryModel
@using NhBackup.WebApplication.Infrastructure
@{
    ViewData["Title"] = Model.Gallery.EnglishTitle ?? Model.Gallery.Id.ToString();

    var groupedTags = Model.Tags?
        .Where(t => t?.Type != null)
        .GroupBy(t => t.Type!.ToLower())
        .OrderBy(g => TagTypes.GetOrder(g.Key))
        .ToList();
}

<style>
    #fullscreenModal {
        background: var(--nh-bg) !important;
    }

        #fullscreenModal .btn {
            transition: all 0.3s ease;
        }

            #fullscreenModal .btn:hover {
                opacity: 1 !important;
                transform: scale(1.1);
            }

            #fullscreenModal .btn:active {
                transform: scale(0.95);
            }

    #counterFullscreen {
        background-color: var(--nh-surface) !important;
        color: var(--nh-text) !important;
    }

    #closeFullscreen,
    #prevFullscreen,
    #nextFullscreen,
    #firstFullscreen,
    #lastFullscreen {
        background-color: var(--nh-surface) !important;
        border-color: var(--nh-border) !important;
        color: var(--nh-text) !important;
    }

        #closeFullscreen:hover,
        #prevFullscreen:hover,
        #nextFullscreen:hover,
        #firstFullscreen:hover,
        #lastFullscreen:hover {
            background-color: var(--nh-tag-bg) !important;
        }
</style>

<div class="row">
    <!-- Left panel with tags -->
    <div class="col-md-3">
        <div class="card" style="height: fit-content;">
            <img src="@Model.PageImages.FirstOrDefault()"
                 class="card-img-top"
                 onerror="this.src='https://via.placeholder.com/300x400?text=No+Cover'"
                 style="height: 300px; object-fit: cover;">
            <div class="card-body">

                <a style="text-decoration: none;" href="https://nhentai.net/g/@Model.Gallery.Id/" target="_blank" title="Open on nhentai: https://nhentai.net/g/@Model.Gallery.Id/">
                    <h5>@Model.Gallery.EnglishTitle</h5>
                    @if (!string.IsNullOrEmpty(Model.Gallery.JapaneseTitle))
                    {
                        <p class="text-muted">@Model.Gallery.JapaneseTitle</p>
                    }
                </a>
                <!-- Favorite button -->
                <div class="d-grid gap-2 mb-3">
                    <button id="favoriteBtn" class="btn @(Model.Gallery.Meta?.IsFavorite == true ? "btn-warning" : "btn-outline-warning")">
                        <i class="bi @(Model.Gallery.Meta?.IsFavorite == true ? "bi-star-fill" : "bi-star")"></i>
                        @(Model.Gallery.Meta?.IsFavorite == true ? "In Favorites" : "Add to Favorites")
                    </button>
                </div>

                <hr />

                <!-- Grouped tags -->
                <div>
                    @if (groupedTags != null && groupedTags.Any())
                    {
                        foreach (var group in groupedTags)
                        {
                            <div class="mb-2">
                                <p class="mb-1"><strong>@TagTypes.GetLabel(group.Key):</strong></p>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var tag in group)
                                    {
                                        <a href="/Browse?SearchTags=@tag.Slug"
                                           class="badge bg-secondary tag-link text-decoration-none">
                                            @tag.Name
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <hr />
                <p><strong>Pages:</strong> @Model.Gallery.NumPages</p>
                <p><strong>ID:</strong> @Model.Gallery.Id</p>
                <a href="/Browse" class="btn btn-secondary w-100 mt-3">← Back</a>
            </div>
        </div>
    </div>

    <!-- Right panel - all pages -->
    <div class="col-md-9">
        @foreach (var imagePath in Model.PageImages)
        {
            <div class="mb-4 text-center">
                <img src="@imagePath"
                     class="img-fluid gallery-image"
                     data-fullscreen="@imagePath"
                     style="cursor: pointer;" />
            </div>
        }
    </div>
</div>

<!-- Fullscreen mode -->
<div id="fullscreenModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;">
    <div style="position: relative; height: 100%; display: flex; align-items: center; justify-content: center;">
        <img id="fullscreenImage" src="" style="height: 100vh; width: auto; max-width: 100%; object-fit: contain;">

        <!-- Top right controls: first, counter, last, close -->
        <div class="position-absolute top-0 end-0 m-3 d-flex align-items-center gap-2">
            <button id="firstFullscreen" class="btn rounded-circle d-flex align-items-center justify-content-center"
                    style="width: 40px; height: 40px; opacity: 0.8;">
                <i class="bi bi-skip-start-fill"></i>
            </button>
            <div id="counterFullscreen" class="rounded-pill d-flex align-items-center justify-content-center px-3"
                 style="height: 40px; opacity: 0.8; font-size: 14px; white-space: nowrap;">
            </div>
            <button id="lastFullscreen" class="btn rounded-circle d-flex align-items-center justify-content-center"
                    style="width: 40px; height: 40px; opacity: 0.8;">
                <i class="bi bi-skip-end-fill"></i>
            </button>
            <button id="closeFullscreen" class="btn rounded-circle d-flex align-items-center justify-content-center"
                    style="width: 40px; height: 40px; opacity: 0.8;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Previous button -->
        <button id="prevFullscreen" class="btn position-absolute start-0 top-50 translate-middle-y ms-3 rounded-circle d-flex align-items-center justify-content-center"
                style="width: 50px; height: 50px; opacity: 0.8;">
            <i class="bi bi-chevron-left fs-4"></i>
        </button>

        <!-- Next button -->
        <button id="nextFullscreen" class="btn position-absolute end-0 top-50 translate-middle-y me-3 rounded-circle d-flex align-items-center justify-content-center"
                style="width: 50px; height: 50px; opacity: 0.8;">
            <i class="bi bi-chevron-right fs-4"></i>
        </button>
    </div>
</div>

@section Scripts {
    <script>
        const images = @Html.Raw(Json.Serialize(Model.PageImages));
        let currentIndex = 0;

        function openFullscreen(index) {
            currentIndex = index;
            document.getElementById('fullscreenImage').src = images[currentIndex];
            document.getElementById('fullscreenModal').style.display = 'block';
            updateCounter();
        }

        function closeFullscreen() {
            document.getElementById('fullscreenModal').style.display = 'none';
        }

        function nextImage() {
            if (currentIndex < images.length - 1) {
                currentIndex++;
                document.getElementById('fullscreenImage').src = images[currentIndex];
                updateCounter();
            }
        }

        function prevImage() {
            if (currentIndex > 0) {
                currentIndex--;
                document.getElementById('fullscreenImage').src = images[currentIndex];
                updateCounter();
            }
        }

        function updateCounter() {
            document.getElementById('counterFullscreen').textContent = `${currentIndex + 1} / ${images.length}`;
        }

        document.querySelectorAll('.gallery-image').forEach((img, idx) => {
            img.addEventListener('click', () => openFullscreen(idx));
        });

        document.getElementById('closeFullscreen').addEventListener('click', closeFullscreen);
        document.getElementById('prevFullscreen').addEventListener('click', prevImage);
        document.getElementById('nextFullscreen').addEventListener('click', nextImage);
        document.getElementById('firstFullscreen').addEventListener('click', () => {
            currentIndex = 0;
            document.getElementById('fullscreenImage').src = images[currentIndex];
            updateCounter();
        });
        document.getElementById('lastFullscreen').addEventListener('click', () => {
            currentIndex = images.length - 1;
            document.getElementById('fullscreenImage').src = images[currentIndex];
            updateCounter();
        });

        document.addEventListener('keydown', (e) => {
            const modal = document.getElementById('fullscreenModal');
            if (modal.style.display === 'block') {
                if (e.key === 'ArrowLeft') prevImage();
                else if (e.key === 'ArrowRight') nextImage();
                else if (e.key === 'Escape') closeFullscreen();
            }
        });

        document.getElementById('fullscreenModal').addEventListener('wheel', (e) => {
            if (e.deltaY > 0) nextImage();
            else if (e.deltaY < 0) prevImage();
            e.preventDefault();
        });

        // Favorite button
        const favoriteBtn = document.getElementById('favoriteBtn');
        const galleryId = @Model.Gallery.Id;

        function showNotification(message, isSuccess) {
            const notification = document.createElement('div');
            notification.className = `alert alert-${isSuccess ? 'success' : 'danger'} position-fixed bottom-0 end-0 m-3`;
            notification.style.zIndex = '10000';
            notification.style.minWidth = '250px';
            notification.innerHTML = message;
            document.body.appendChild(notification);
            setTimeout(() => notification.remove(), 3000);
        }

        favoriteBtn.addEventListener('click', async () => {
            try {
                const response = await fetch(`/api/favorite/toggle/${galleryId}`, { method: 'POST' });
                const result = await response.json();

                if (result.success) {
                    if (result.isFavorite) {
                        favoriteBtn.className = 'btn btn-warning';
                        favoriteBtn.innerHTML = '<i class="bi bi-star-fill"></i> In Favorites';
                    } else {
                        favoriteBtn.className = 'btn btn-outline-warning';
                        favoriteBtn.innerHTML = '<i class="bi bi-star"></i> Add to Favorites';
                    }
                    showNotification(result.message, true);
                } else {
                    showNotification(result.message || 'Error', false);
                }
            } catch {
                showNotification('Error occurred', false);
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'f' || e.key === 'F') {
                e.preventDefault();
                favoriteBtn.click();
            }
        });
    </script>
}
