@page "{id}"
@model NhBackup.WebApplication.Pages.GalleryModel
@{
    ViewData["Title"] = Model.Gallery.EnglishTitle ?? Model.Gallery.Id.ToString();
}

<style>
    /* Стили только для этой страницы */
    #fullscreenModal .btn {
        transition: all 0.3s ease;
    }

        #fullscreenModal .btn:hover {
            opacity: 1 !important;
            transform: scale(1.1);
        }

        #fullscreenModal .btn:active {
            transform: scale(0.95);
        }

    [data-bs-theme="light"] #fullscreenModal {
        background: rgba(255, 255, 255, 0.95) !important;
    }

        [data-bs-theme="light"] #fullscreenModal .btn {
            background-color: #e9ecef;
            color: #212529;
            border: 1px solid #dee2e6;
        }

        [data-bs-theme="light"] #fullscreenModal .rounded-pill {
            background-color: #e9ecef !important;
            color: #212529 !important;
        }
</style>

<div class="row">
    <!-- Левая панель с тегами -->
    <div class="col-md-3">
        <div class="card">
            <img src="@Model.PageImages.FirstOrDefault()"
                 class="card-img-top"
                 onerror="this.src='https://via.placeholder.com/300x400?text=No+Cover'"
                 style="height: 300px; object-fit: cover;">
            <div class="card-body">
                <h5>@Model.Gallery.EnglishTitle</h5>

                @if (!string.IsNullOrEmpty(Model.Gallery.JapaneseTitle))
                {
                    <p class="text-muted">@Model.Gallery.JapaneseTitle</p>
                }
                <!-- Кнопка избранного -->
                <div class="d-grid gap-2 mb-3">
                    <button id="favoriteBtn" class="btn @(Model.Gallery.IsFavorite ? "btn-warning" : "btn-outline-warning")">
                        <i class="bi @(Model.Gallery.IsFavorite ? "bi-star-fill" : "bi-star")"></i>
                        @(Model.Gallery.IsFavorite ? "В избранном" : "В избранное")
                    </button>
                </div>
                <hr />

                <p><strong>Теги:</strong></p>
                <div style="max-height: 400px; overflow-y: auto;">
                    @if (Model.Tags != null && Model.Tags.Any())
                    {
                        foreach (var tag in Model.Tags)
                        {
                            <div class="mb-1">
                                <span class="badge bg-secondary" style="display: block; text-align: left;">
                                    @tag?.Name
                                </span>
                            </div>
                        }
                    }
                </div>

                <hr />
                <p><strong>Страниц:</strong> @Model.Gallery.NumPages</p>
                <p><strong>ID:</strong> @Model.Gallery.Id</p>
                <a href="/Browse" class="btn btn-secondary w-100 mt-3">← Назад</a>
            </div>
        </div>
    </div>

    <!-- Правая часть - все страницы -->
    <div class="col-md-9">
        @foreach (var imagePath in Model.PageImages)
        {
            <div class="mb-4 text-center">
                <img src="@imagePath"
                     class="img-fluid gallery-image"
                     data-fullscreen="@imagePath"
                     style="cursor: pointer;" />
            </div>
        }
    </div>
</div>

<!-- Полноэкранный режим -->
<div id="fullscreenModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--bs-body-bg); z-index: 9999;">
    <div style="position: relative; height: 100%; display: flex; align-items: center; justify-content: center;">
        <img id="fullscreenImage" src="" style="max-width: 90%; max-height: 90%; object-fit: contain;">

        <!-- Кнопка закрыть -->
        <button id="closeFullscreen" class="btn btn-dark position-absolute top-0 end-0 m-3 rounded-circle d-flex align-items-center justify-content-center"
                style="width: 40px; height: 40px; opacity: 0.7;">
            <i class="bi bi-x-lg"></i>
        </button>

        <!-- Кнопка назад -->
        <button id="prevFullscreen" class="btn btn-dark position-absolute start-0 top-50 translate-middle-y ms-3 rounded-circle d-flex align-items-center justify-content-center"
                style="width: 50px; height: 50px; opacity: 0.7;">
            <i class="bi bi-chevron-left fs-4"></i>
        </button>

        <!-- Кнопка вперед -->
        <button id="nextFullscreen" class="btn btn-dark position-absolute end-0 top-50 translate-middle-y me-3 rounded-circle d-flex align-items-center justify-content-center"
                style="width: 50px; height: 50px; opacity: 0.7;">
            <i class="bi bi-chevron-right fs-4"></i>
        </button>

        <!-- Счетчик -->
        <div id="counterFullscreen" class="position-absolute bottom-0 start-50 translate-middle-x mb-3 px-3 py-1 rounded-pill bg-dark text-white"
             style="opacity: 0.8; font-size: 14px;">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Собираем все картинки
        const images = @Html.Raw(Json.Serialize(Model.PageImages));
        let currentIndex = 0;

        // Открыть полноэкранный режим
        function openFullscreen(index) {
            currentIndex = index;
            const img = document.getElementById('fullscreenImage');
            img.src = images[currentIndex];
            document.getElementById('fullscreenModal').style.display = 'block';
            updateCounter();
        }

        // Закрыть
        function closeFullscreen() {
            document.getElementById('fullscreenModal').style.display = 'none';
        }

        // Следующая
        function nextImage() {
            if (currentIndex < images.length - 1) {
                currentIndex++;
                document.getElementById('fullscreenImage').src = images[currentIndex];
                updateCounter();
            }
        }

        // Предыдущая
        function prevImage() {
            if (currentIndex > 0) {
                currentIndex--;
                document.getElementById('fullscreenImage').src = images[currentIndex];
                updateCounter();
            }
        }

        // Обновить счетчик
        function updateCounter() {
            document.getElementById('counterFullscreen').textContent = `${currentIndex + 1} / ${images.length}`;
        }

        // Навешиваем обработчики на все картинки
        document.querySelectorAll('.gallery-image').forEach((img, idx) => {
            img.addEventListener('click', () => openFullscreen(idx));
        });

        // Кнопки управления
        document.getElementById('closeFullscreen').addEventListener('click', closeFullscreen);
        document.getElementById('prevFullscreen').addEventListener('click', prevImage);
        document.getElementById('nextFullscreen').addEventListener('click', nextImage);

        // Стрелки на клавиатуре
        document.addEventListener('keydown', (e) => {
            const modal = document.getElementById('fullscreenModal');
            if (modal.style.display === 'block') {
                if (e.key === 'ArrowLeft') {
                    prevImage();
                } else if (e.key === 'ArrowRight') {
                    nextImage();
                } else if (e.key === 'Escape') {
                    closeFullscreen();
                }
            }
        });

        // Колесо мыши для навигации
        document.getElementById('fullscreenModal').addEventListener('wheel', (e) => {
            if (e.deltaY > 0) {
                nextImage();
            } else if (e.deltaY < 0) {
                prevImage();
            }
            e.preventDefault();
        });

                // Кнопка избранного
        const favoriteBtn = document.getElementById('favoriteBtn');
        const galleryId = @Model.Gallery.Id;

        // Функция уведомления
        function showNotification(message, isSuccess) {
            const notification = document.createElement('div');
            notification.className = `alert alert-${isSuccess ? 'success' : 'danger'} position-fixed bottom-0 end-0 m-3`;
            notification.style.zIndex = '10000';
            notification.style.minWidth = '250px';
            notification.innerHTML = message;
            document.body.appendChild(notification);

            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        favoriteBtn.addEventListener('click', async () => {
            try {
                const response = await fetch(`/api/favorite/toggle/${galleryId}`, {
                    method: 'POST'
                });

                const result = await response.json();

                if (result.success) {
                    // Обновляем кнопку
                    if (result.isFavorite) {
                        favoriteBtn.className = 'btn btn-warning';
                        favoriteBtn.innerHTML = '<i class="bi bi-star-fill"></i> В избранном';
                    } else {
                        favoriteBtn.className = 'btn btn-outline-warning';
                        favoriteBtn.innerHTML = '<i class="bi bi-star"></i> В избранное';
                    }
                    showNotification(result.message, true);
                } else {
                    showNotification(result.message || 'Ошибка', false);
                }
            } catch (error) {
                showNotification('Ошибка при выполнении', false);
            }
        });

        // Кнопка F на клавиатуре
        document.addEventListener('keydown', (e) => {
            if (e.key === 'f' || e.key === 'F') {
                e.preventDefault();
                favoriteBtn.click();
            }
        });
    </script>
}
